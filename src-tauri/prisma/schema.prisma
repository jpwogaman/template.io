datasource db {
    provider = "sqlite"
    url      = "file:../dev.db"
}

generator client {
    provider    = "cargo prisma"
    output      = "../src/db.rs"
    module_path = "crate::db"
}

model Post {
    id        String   @id @default(cuid())
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    published Boolean
    title     String
    content   String?
    desc      String?
}